generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id                String       @id @default(auto()) @map("_id") @db.ObjectId
  username          String       @unique
  email             String       @unique
  password          String       @default("")
  elo               Int          @default(500)
  wins              Int          @default(0)
  losses            Int          @default(0)
  draws             Int          @default(0)
  discordId         String?
  discordUsername   String?
  discordHighestElo Int          @default(0)
  role              String       @default("user")
  badgePrefs        String[]     @default([])
  animationsEnabled Boolean      @default(true)
  gameBackground    String       @default("default")
  resetToken        String?
  resetTokenExpiry  DateTime?
  createdAt         DateTime     @default(now())
  decks             Deck[]
  gamesAsPlayer1    Game[]       @relation("Player1")
  gamesAsPlayer2    Game[]       @relation("Player2")
  quizScores        QuizScore[]
  friendshipsSent     Friendship[]  @relation("FriendshipSent")
  friendshipsReceived Friendship[]  @relation("FriendshipReceived")
  matchInvitesSent     MatchInvite[] @relation("MatchInviteSent")
  matchInvitesReceived MatchInvite[] @relation("MatchInviteReceived")
  accounts          Account[]
  tournamentWins    Int          @default(0)
  chatBanned        Boolean      @default(false)
  chatBanUntil      DateTime?
  gameBanned        Boolean      @default(false)
  gameBanUntil      DateTime?
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Deck {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  userId     String   @db.ObjectId
  user       User     @relation(fields: [userId], references: [id])
  cardIds    String[]
  missionIds String[]
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Game {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  player1Id    String?   @db.ObjectId
  player2Id    String?   @db.ObjectId
  player1      User?     @relation("Player1", fields: [player1Id], references: [id])
  player2      User?     @relation("Player2", fields: [player2Id], references: [id])
  isAiGame     Boolean   @default(false)
  aiDifficulty String?
  status       String
  winnerId     String?   @db.ObjectId
  gameState    Json?
  player1Score Int       @default(0)
  player2Score Int       @default(0)
  eloChange    Int?
  createdAt    DateTime  @default(now())
  completedAt  DateTime?
}

model Room {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  code      String   @unique
  hostId    String   @db.ObjectId
  guestId   String?  @db.ObjectId
  gameId    String?  @db.ObjectId
  status    String
  isPrivate Boolean  @default(false)
  createdAt DateTime @default(now())
}

model QuizScore {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
  difficulty  Int
  score       Int
  correct     Int
  total       Int
  accuracy    Float
  bestStreak  Int
  completedAt DateTime @default(now())
}

model Friendship {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  senderId   String   @db.ObjectId
  receiverId String   @db.ObjectId
  sender     User     @relation("FriendshipSent", fields: [senderId], references: [id])
  receiver   User     @relation("FriendshipReceived", fields: [receiverId], references: [id])
  status     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([senderId, receiverId])
}

model MatchInvite {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  senderId   String   @db.ObjectId
  receiverId String   @db.ObjectId
  sender     User     @relation("MatchInviteSent", fields: [senderId], references: [id])
  receiver   User     @relation("MatchInviteReceived", fields: [receiverId], references: [id])
  roomCode   String?
  status     String
  createdAt  DateTime @default(now())
  expiresAt  DateTime
}


model BannedCard {
  id       String   @id @default(auto()) @map("_id") @db.ObjectId
  cardId   String   @unique
  bannedAt DateTime @default(now())
}

model SiteSettings {
  id              String  @id @default(auto()) @map("_id") @db.ObjectId
  key             String  @unique
  leaguesEnabled  Boolean @default(false)
  sealedEnabled   Boolean @default(false) @map("draftEnabled")
  discordRoleIds  Json?
}

model GameBackground {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String   @unique
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model Tournament {
  id                 String                  @id @default(auto()) @map("_id") @db.ObjectId
  name               String
  type               String
  status             String
  gameMode           String
  maxPlayers         Int
  currentRound       Int                     @default(0)
  totalRounds        Int                     @default(0)
  isPublic           Boolean                 @default(true)
  joinCode           String?                 @unique
  creatorId          String                  @db.ObjectId
  creatorUsername     String
  requiresDiscord    Boolean                 @default(false)
  useBanList         Boolean                 @default(true)
  sealedBoosterCount Int?
  discordRoleReward  String?
  discordRoleBadge   String?
  bannedCardIds      String[]                @default([])
  allowedLeagues     String[]                @default([])
  startedAt          DateTime?
  completedAt        DateTime?
  winnerId           String?                 @db.ObjectId
  winnerUsername      String?
  createdAt          DateTime                @default(now())
  participants       TournamentParticipant[]
  matches            TournamentMatch[]
}

model TournamentParticipant {
  id              String     @id @default(auto()) @map("_id") @db.ObjectId
  tournamentId    String     @db.ObjectId
  tournament      Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  userId          String     @db.ObjectId
  username        String
  seed            Int?
  eliminated      Boolean    @default(false)
  eliminatedRound Int?
  hasBye          Boolean    @default(false)
  sealedPool      Json?
  sealedDeck      Json?
  joinedAt        DateTime   @default(now())

  @@unique([tournamentId, userId])
}

model TournamentMatch {
  id              String     @id @default(auto()) @map("_id") @db.ObjectId
  tournamentId    String     @db.ObjectId
  tournament      Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  round           Int
  matchIndex      Int
  player1Id       String?    @db.ObjectId
  player2Id       String?    @db.ObjectId
  player1Username String?
  player2Username String?
  winnerId        String?    @db.ObjectId
  winnerUsername   String?
  isBye           Boolean    @default(false)
  status          String
  roomCode        String?
  gameId          String?    @db.ObjectId
  absenceDeadline DateTime?
  absentPlayerId  String?    @db.ObjectId
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime   @default(now())

  @@unique([tournamentId, round, matchIndex])
}

model CardIssue {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  cardIds     String[] // Array of card IDs sharing the same issue
  cardNames   String[] // Parallel array of card names
  description String
  status      String   @default("to_fix") // to_fix | fixed_unpublished | fixed_published | verified
  reportedBy  String
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ChatMessage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  roomCode  String
  userId    String   @db.ObjectId
  username  String
  message   String
  isEmote   Boolean  @default(false)
  isSpectator Boolean @default(false)
  createdAt DateTime @default(now())
}

model ChatReport {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  messageId       String
  reporterId      String    @db.ObjectId
  reporterName    String
  targetId        String    @db.ObjectId
  targetName      String
  messageText     String
  roomCode        String
  reason          String    @default("")
  status          String    @default("pending")
  createdAt       DateTime  @default(now())
  resolvedAt      DateTime?
  resolvedBy      String?
  action          String?
  reporterNotified Boolean  @default(false)
  reporterReward   Int?
}

model UserBan {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  userId      String    @db.ObjectId
  username    String
  type        String
  permanent   Boolean   @default(false)
  expiresAt   DateTime?
  reason      String    @default("")
  issuedBy    String    @db.ObjectId
  createdAt   DateTime  @default(now())
}

model Suggestion {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String
  category    String   // gameplay | ui | cards | balance | social | other
  status      String   @default("backlog") // backlog | planned | in_progress | done_unpublished | done_published | rejected
  priority    String   @default("normal") // low | normal | high | critical
  images      String[] // base64 data URLs
  audioUrl    String?  // base64 data URL for audio
  submittedBy String
  assignedTo  String?
  updatedBy   String?
  adminNotes  String?
  upvotes     Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
