{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "resolveJsonModule": true,
    "baseUrl": "..",
    "paths": {
      "@/*": ["./*"]
    },
    "types": ["node"]
  },
  "ts-node": {
    "transpileOnly": true,
    "files": true
  },
  "files": [
    "selfplay.ts",
    "benchmark.ts"
  ],
  "exclude": ["../node_modules"]
}
