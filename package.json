{
  "name": "naruto-mythos-game",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:server": "node --import tsx server/index.ts",
    "build": "prisma generate && next build",
    "start": "next start",
    "start:server": "node --import tsx server/index.ts",
    "lint": "eslint",
    "selfplay": "node -r tsconfig-paths/register node_modules/ts-node/dist/bin.js --project scripts/tsconfig.json scripts/selfplay.ts",
    "selfplay:parallel": "node -r tsconfig-paths/register node_modules/ts-node/dist/bin.js --project scripts/tsconfig.json scripts/selfplayParallel.ts",
    "benchmark": "node -r tsconfig-paths/register node_modules/ts-node/dist/bin.js --project scripts/tsconfig.json scripts/benchmark.ts",
    "benchmark:tournament": "node -r tsconfig-paths/register node_modules/ts-node/dist/bin.js --project scripts/tsconfig.json scripts/benchmarkTournament.ts",
    "export:decks": "node -r tsconfig-paths/register node_modules/ts-node/dist/bin.js --project scripts/tsconfig.json scripts/exportStrongDecks.ts",
    "merge:decks": "node -r tsconfig-paths/register node_modules/ts-node/dist/bin.js --project scripts/tsconfig.json scripts/mergeStrongDecks.ts",
    "merge:selfplay": "node -r tsconfig-paths/register node_modules/ts-node/dist/bin.js --project scripts/tsconfig.json scripts/mergeSelfplayOutputs.ts",
    "test": "vitest run",
    "duel": "node -r tsconfig-paths/register node_modules/ts-node/dist/bin.js --project scripts/tsconfig.json scripts/benchmarkParallel.ts --a impossible --b impossible --a-mode heuristic --b-mode heuristic --a-sims 150 --b-sims 150 --games 100 --decks ai_training/strong_decks_curated.json --output scripts/bench/duel_result.json",
    "duel:fast": "node -r tsconfig-paths/register node_modules/ts-node/dist/bin.js --project scripts/tsconfig.json scripts/benchmarkParallel.ts --a impossible --b impossible --a-mode heuristic --b-mode heuristic --a-sims 100 --b-sims 100 --games 50 --decks ai_training/strong_decks_curated.json --output scripts/bench/duel_result.json",
    "duel:neural": "node -r tsconfig-paths/register node_modules/ts-node/dist/bin.js --project scripts/tsconfig.json scripts/benchmarkParallel.ts --a impossible --b impossible --a-mode neural --b-mode heuristic --a-sims 250 --b-sims 250 --games 100 --workers 4 --decks ai_training/strong_decks_curated.json --output scripts/bench/duel_result.json"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^3.0.3",
    "express": "^5.2.1",
    "framer-motion": "^12.34.0",
    "next": "16.1.6",
    "next-auth": "5.0.0-beta.30",
    "next-intl": "^4.8.3",
    "onnxruntime-web": "^1.24.2",
    "prisma": "^6.19.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.9.2",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.19.0",
    "uuid": "^13.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^11.0.0",
    "discord.js": "^14.25.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.0.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "optionalDependencies": {
    "onnxruntime-node": "^1.20.1"
  }
}
