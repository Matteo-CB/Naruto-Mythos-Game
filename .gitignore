# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env
output/
.claude/
nul

# brute-force script data
newvisual/brute*_progress.json

# AI training — checkpoints lourds (garder uniquement .onnx et _meta.json)
public/models/*.pth
public/models/checkpoint_*.pth
public/models/training_history.png

# Données de self-play (peuvent être très volumineuses)
scripts/training_data*.json
scripts/expert_iter_*.json
scripts/expert_iteration_pool.json
scripts/bench/
ai_training/__pycache__/
ai_training/*.pyc
